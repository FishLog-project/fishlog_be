# .env 템플릿 (실제 파일 .env는 gitignore됨) - docker-compose.yml이 ../.env로 읽음
# MYSQL_PASSWORD와 SPRING_DATASOURCE_PASSWORD는 동일한 값으로 설정.
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
SPRING_DATASOURCE_PASSWORD=

# redis: 컨테이너 requirepass와 앱 접속 비밀번호(동일 값). docker-compose.yml redis/api가 사용.
SPRING_DATA_REDIS_PASSWORD=
